-- damage_tracker.script
-- Логирование урона актора с классификацией из damage_modifier.txt

local function safe_tostring(val)
    local ok, result = pcall(tostring, val)
    if ok then return result else return "<error converting>" end
end

-- Функция для безопасного вызова методов userdata (без аргументов)
local function safe_call_method(obj, method_name)
    if type(obj) ~= "userdata" then
        return false, nil
    end
    local ok, result = pcall(function()
        if obj[method_name] then
            return obj[method_name](obj)
        end
        return nil
    end)
    if ok and result ~= nil then
        return true, result
    else
        return false, nil
    end
end

-- ============================================================================
-- ИНТЕГРАЦИЯ С DAMAGE_MODIFIER.TXT: Маппинги и классификация урона
-- ============================================================================

-- Маппинг ID типа урона в категорию (из damage_modifier.txt)
local damage_type_to_category = {
    [0] = "rupture",
    [1] = "burn",
    [2] = "electrical",
    [3] = "impact",
    [4] = "explosive",
    [5] = "ballistic",
    [6] = "chemical",
    [7] = "radiation",
    [8] = "psy",
    [9] = "burn",
    [10] = "chemical",
    [11] = "burn",
    [12] = "impact"
}

-- Точные маппинги источников урона (ключевые паттерны из damage_modifier.txt)
local exact_source_mappings = {
    -- BURN DAMAGE
    ["zone_zhar"] = "burn",
    ["zone_field_thermal"] = "burn",
    ["zone_mine_thermal"] = "burn",
    ["fireball_zone"] = "burn",
    ["generator_torrid"] = "burn",
    ["burer_fire"] = "burn",
    ["torrid"] = "burn",
    ["thermal"] = "burn",
    ["fire"] = "burn",
    ["burn"] = "burn",
    
    -- CHEMICAL DAMAGE
    ["zone_field_acidic"] = "chemical",
    ["zone_mine_acidic"] = "chemical",
    ["fireball_acidic_zone"] = "chemical",
    ["zone_burning_fuzz"] = "chemical",
    ["zone_liana"] = "chemical",
    ["acidic"] = "chemical",
    ["chemical"] = "chemical",
    ["acid"] = "chemical",
    
    -- ELECTRICAL DAMAGE
    ["zone_field_electric"] = "electrical",
    ["zone_mine_electric"] = "electrical",
    ["fireball_electric_zone"] = "electrical",
    ["generator_electra"] = "electrical",
    ["electr"] = "electrical",
    ["shock"] = "electrical",
    ["tesla"] = "electrical",
    ["electric"] = "electrical",
    
    -- RADIATION DAMAGE
    ["zone_field_radioactive"] = "radiation",
    ["zone_mine_radioactive"] = "radiation",
    ["radioactive"] = "radiation",
    ["radiation"] = "radiation",
    ["rad"] = "radiation",
    
    -- PSYCHIC DAMAGE
    ["zone_field_psychic"] = "psy",
    ["zone_monolith"] = "psy",
    ["psy_dog_phantom"] = "psy",
    ["m_controller"] = "psy",
    ["m_burer"] = "psy",
