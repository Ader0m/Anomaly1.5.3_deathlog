    -- BALLISTIC DAMAGE (weapons)
    ["wpn_"] = "ballistic",
    ["stalker"] = "ballistic",
    ["mounted_weapon"] = "ballistic",
    
    -- RUPTURE DAMAGE (mutants/melee)
    ["m_bloodsucker"] = "rupture",
    ["m_boar"] = "rupture",
    ["m_chimera"] = "rupture",
    ["m_dog"] = "rupture",
    ["m_gigant"] = "rupture",
