-- Паттерны для поиска по подстроке (упрощённая версия из damage_modifier.txt)
local source_patterns = {
    burn = {"thermal", "fire", "burn", "flame", "heat", "hot", "scorch", "torrid"},
    chemical = {"acidic", "acid", "chemical", "toxic", "poison", "corros", "chem", "liana"},
    electrical = {"electric", "electr", "shock", "tesla", "spark", "volt", "static"},
    radiation = {"radioactive", "radiation", "rad", "atom", "nuclear"},
    psy = {"psychic", "brain", "mental", "monolith", "controller", "burer", "phantom"},
    ballistic = {"wpn_", "weapon", "bullet", "shot", "gun", "rifle", "pistol"},
    rupture = {"bloodsucker", "boar", "chimera", "dog", "gigant", "snork", "mutant", "claw", "bite", "knife", "axe"},
    gravitational = {"gravitational", "gravity"},
    explosive = {"explosive", "explosion", "blast", "grenade", "rpg"},
    impact = {"kinetic", "strike", "teleport", "anomaly", "field"}
}

-- Функция проверки паттернов источника (из damage_modifier.txt)
local function check_source_patterns(source_lower, source_name)
    -- Проверка точных совпадений
    if exact_source_mappings[source_name] then
        return exact_source_mappings[source_name]
    end
    
    -- Проверка по паттернам
    for category, patterns in pairs(source_patterns) do
        for _, pattern in ipairs(patterns) do
            if string.find(source_lower, pattern, 1, true) then
                return category
            end
        end
    end
    
    -- Проверка частичных совпадений с точными маппингами
    for exact_name, category in pairs(exact_source_mappings) do
        if string.find(source_lower, exact_name, 1, true) then
            return category
        end
    end
    
    return nil
end

-- Функция для получения категории урона с учетом оружия (из damage_modifier.txt)
local function get_damage_category(damage_type, source_name, s_hit)
    -- Сначала пробуем стандартный маппинг по ID типа урона
    local category = damage_type_to_category[damage_type]
    
    -- Если тип урона 0 (rupture) или 6 (chemical), но источник - сталкер/враг,
    -- это скорее всего пулевое оружие, а не химия/ melee
    if source_name then
        local source_lower = string.lower(source_name)
        
        -- Проверка: если источник содержит "stalker", "sim_default", "esc_" и т.д. - это NPC с оружием
        if string.find(source_lower, "stalker") or 
           string.find(source_lower, "sim_default") or
           string.find(source_lower, "esc_") or
           string.find(source_lower, "wolf") or
           string.find(source_lower, "fanat") then
            -- Это NPC, скорее всего стреляет из оружия -> ballistic
            category = "ballistic"
        end
        
        -- Проверка по паттернам источников
        if not category or category == "other" then
            category = check_source_patterns(source_lower, source_name)
        end
    end
    
    return category or "other"
end

-- Функция для получения имени источника из объекта
local function get_source_name(who)
    if not who then
        return nil
    end
    
    -- Если who - это строка (ID объекта), пытаемся найти объект и получить его имя
    if type(who) == "string" then
        local ok, obj = pcall(function()
            return alife():object(who)
        end)
        if ok and obj then
            local ok_name, name = pcall(function()
                return obj:name()
            end)
            if ok_name and name then
                return name
            end
        end
        return who -- Возвращаем ID если не нашли объект
    end
    
    if type(who) == "userdata" then
        -- Пробуем получить отображаемое имя через name()
        local ok, name = safe_call_method(who, "name")
        if ok and name then
            return name
        end
    end
    
    return safe_tostring(who)
end

-- Функция для получения игрового имени мутанта (из системного имени)
-- Например: mutant_flesh_strong -> Плоть, mutant_dog_weak -> Слепая собака
-- Устарела, используется get_mutant_name() из словаря мутантов
local function get_mutant_game_name(sys_name)
    -- Сначала пробуем новый словарь мутантов (быстрее и надёжнее)
    local name = get_mutant_name(sys_name)
    if name then
        return name
    end
    
    -- Если не нашли в словаре, пробуем старый метод через st.get()
    if not sys_name or type(sys_name) ~= "string" then
        return nil
    end
    
    -- Проверяем, является ли объект мутантом по префиксу
    if not string.find(sys_name, "^mutant_") then
        return nil
    end
    
    -- Используем st.get() для получения локализированного игрового имени
    local ok, game_name = pcall(function()
        return st.get(sys_name)
    end)
    
    if ok and game_name and game_name ~= "" and game_name ~= sys_name then
        return game_name
    end
    
    -- Если st.get() не сработал, пробуем альтернативный вариант
    -- Иногда имена хранятся с префиксом st_mutant_
    local alt_name = "st_" .. sys_name
    local ok_alt, game_name_alt = pcall(function()
        return st.get(alt_name)
    end)
    
    if ok_alt and game_name_alt and game_name_alt ~= "" and game_name_alt ~= alt_name then
        return game_name_alt
    end
    
    return nil
end

-- Функция для получения строкового имени типа урона
local function get_hit_type_name(s_hit)
    if type(s_hit) ~= "userdata" then
        return nil
    end
    
    -- Пробуем вызвать метод type_name() который возвращает строку ("wound", "strike", "bullet" и т.д.)
    local ok, type_name = pcall(function()
        if s_hit.type_name then
            return s_hit:type_name()
        end
        return nil
    end)
    
    if ok and type_name then
        return type_name
    end
    
    return nil
end

local function safe_log(...)
    -- log() пишет в xray.log, print() только в консоль отладки
    -- Используем varargs (...) вместо string.format для безопасности
    log(...)
end


-- Глобальная переменная для хранения здоровья до удара
local hp_before = nil
-- Глобальная переменная для хранения типа урона
local damage_type_before = nil
-- Глобальная переменная для хранения структуры хита
local hit_struct_before = nil
-- Глобальная переменная для хранения финального урона из power()
local final_damage_from_power = nil

-- Регистрируем callback через систему скриптовых коллбэков
function on_game_start()
    RegisterScriptCallback("actor_on_before_hit", actor_on_before_hit)
    RegisterScriptCallback("actor_on_hit_callback", actor_on_hit_callback)
    safe_log("[DAMAGE_TRACKER] Registered actor_on_before_hit callback")
    safe_log("[DAMAGE_TRACKER] Registered actor_on_hit_callback callback")
end

-- Callback для сохранения здоровья ДО получения урона
-- Params: (shit, bone_id, flags) где shit - структура хита
function actor_on_before_hit(shit, bone_id, flags)
    -- Сохраняем структуру хита для дальнейшего анализа
    hit_struct_before = shit
    
    -- Сохраняем здоровье актёра до применения урона
    if db.actor then
        local ok_hp, hp_val = pcall(function() return db.actor.health end)
        if ok_hp and hp_val then
            hp_before = hp_val
            safe_log("[DAMAGE_TRACKER] HP before hit: " .. tostring(hp_before))
        end
        
        -- Сохраняем тип урона из структуры хита
        if shit and type(shit) == "userdata" then
            local ok_dtype, dtype_val = pcall(function() return shit:type() end)
            if ok_dtype and dtype_val then
                damage_type_before = dtype_val
                safe_log("[DAMAGE_TRACKER] Damage type before hit: " .. tostring(damage_type_before))
            end
            
            -- Пытаемся получить базовый урон из хита (amount)
            local ok_amount, amount_val = pcall(function() return shit:amount() end)
            if ok_amount and amount_val then
                safe_log("[DAMAGE_TRACKER] Hit amount (base from hit struct): " .. tostring(amount_val))
            end
            
            -- Логируем bone из хита для отладки
            local ok_hbone, hbone_val = pcall(function() return shit:bone() end)
            if ok_hbone and hbone_val then
                safe_log("[DAMAGE_TRACKER] Hit bone (from hit struct): " .. tostring(hbone_val))
            end
            
            -- Получаем power и impulse которые могут быть модифицированы
            local ok_power, power_val = pcall(function() return shit:power() end)
            if ok_power and power_val then
                safe_log("[DAMAGE_TRACKER] Hit power: " .. tostring(power_val))
                -- Сохраняем power как потенциальный финальный урон
                final_damage_from_power = power_val
            end
            
            local ok_impulse, impulse_val = pcall(function() return shit:impulse() end)
            if ok_impulse and impulse_val then
                safe_log("[DAMAGE_TRACKER] Hit impulse: " .. tostring(impulse_val))
            end
        end
    end
end

-- Callback для обработки попадания в актёра (вычисляет реальный урон через разницу здоровья)
-- Params: (obj, amount, local_direction, who, bone_index)
function actor_on_hit_callback(obj, amount, local_direction, who, bone_index)
    safe_log("[DAMAGE_TRACKER] CALLBACK FIRED (actor_on_hit_callback)")
    
    -- Диагностика типа параметров
    safe_log("[DAMAGE_TRACKER] obj type: " .. type(obj))
    safe_log("[DAMAGE_TRACKER] amount (base): " .. safe_tostring(amount))
    safe_log("[DAMAGE_TRACKER] bone_index: " .. safe_tostring(bone_index))
    safe_log("[DAMAGE_TRACKER] hp_before value: " .. safe_tostring(hp_before))
    safe_log("[DAMAGE_TRACKER] hit_struct_before exists: " .. safe_tostring(hit_struct_before ~= nil))
    
    -- Вычисляем реальный урон через разницу здоровья
    local hp_after = -1
    if db.actor then
        local ok_hp, hp_val = pcall(function() return db.actor.health end)
        if ok_hp then
            hp_after = hp_val
            safe_log("[DAMAGE_TRACKER] HP after (current): " .. tostring(hp_after))
        end
    end
    
    local real_damage = 0
    local used_power_fallback = false
    
    if hp_before and hp_after >= 0 and hp_before >= 0 then
        real_damage = hp_before - hp_after
        -- Умножаем на 100 для UI-формата (здоровье в диапазоне 0.0–1.0)
        real_damage = real_damage * 100
        safe_log("[DAMAGE_TRACKER] HP before: " .. tostring(hp_before) .. ", HP after: " .. tostring(hp_after))
        safe_log("[DAMAGE_TRACKER] HP DIFFERENCE (raw): " .. tostring(hp_before - hp_after))
        safe_log("[DAMAGE_TRACKER] REAL DAMAGE calculated: " .. tostring(real_damage))
        
        -- Если разница равна 0, проверяем power() из hit структуры как fallback
        if real_damage <= 0 then
            safe_log("[DAMAGE_TRACKER] WARNING: Zero damage from HP difference")
            -- Используем сохранённый final_damage_from_power если он есть
            if final_damage_from_power and final_damage_from_power > 0 then
                -- Конвертируем power в тот же формат (умножаем на 100)
                real_damage = final_damage_from_power * 100
                used_power_fallback = true
                safe_log("[DAMAGE_TRACKER] Using power() as fallback damage: " .. tostring(real_damage))
            end
        end
    else
        -- Если hp_before не установлен, используем amount как запасной вариант
        real_damage = amount or 0
        safe_log("[DAMAGE_TRACKER] WARNING: hp_before not set, using base amount as fallback: " .. tostring(real_damage))
    end
    
    -- Сбрасываем hp_before для следующего удара
    hp_before = nil
    hit_struct_before = nil
    final_damage_from_power = nil
    
    if real_damage <= 0 then
        safe_log("[DAMAGE_TRACKER] Skipping hit with zero or negative damage (armor blocked or miss)")
        return
    end
    
    if used_power_fallback then
        safe_log("[DAMAGE_TRACKER] FINAL DAMAGE (from power fallback): " .. tostring(real_damage))
    else
        safe_log("[DAMAGE_TRACKER] FINAL DAMAGE (after modifiers/armor): " .. tostring(real_damage))
    end
    
    local bone_id = bone_index or 0
    
    -- Получаем категорию и название кости
    local bone_category = get_bone_category(bone_id)
    local bone_name_ru = get_bone_name_ru(bone_id)
    safe_log("[DAMAGE_TRACKER] Bone Category: " .. bone_category .. " | Bone Name (RU): " .. bone_name_ru)
    
    -- Получаем имя источника для классификации
    local source_name = get_source_name(who)
    safe_log("[DAMAGE_TRACKER] Who (raw): " .. safe_tostring(source_name or "nil"))
    
    -- Пытаемся получить отображаемое имя через alife объект если who это game_object
    local display_name = source_name
    if who and type(who) == "userdata" then
        -- Сначала пробуем получить character_name напрямую из game_object (это игровое имя типа "Хип", "Вася пупкин")
        local ok_char_name, char_name = pcall(function() return who:character_name() end)
        if ok_char_name and char_name and char_name ~= "" then
            display_name = char_name
            safe_log("[DAMAGE_TRACKER] Display name from character_name: " .. char_name)
        else
            -- Если character_name не доступен, пробуем получить nickname
            local ok_nick, nickname = pcall(function() return who:nickname() end)
            if ok_nick and nickname and nickname ~= "" then
                display_name = nickname
                safe_log("[DAMAGE_TRACKER] Display name from nickname: " .. nickname)
            else
                -- Для мутантов пробуем получить игровое имя через словарь мутантов
                -- Это позволяет перевести системное имя (boar_02a_weak26696, mutant_flesh_strong) в игровое (Кабан, Плоть)
                local sys_name = source_name
                if sys_name then
                    local mutant_game_name = get_mutant_name(sys_name)
                    if mutant_game_name then
                        display_name = mutant_game_name
                        safe_log("[DAMAGE_TRACKER] Display name from mutant_name dictionary: " .. mutant_game_name)
                    end
                end
                
                -- Если имя мутанта не найдено, пробуем alife объект
                if display_name == source_name then
                    local ok_who_id, obj_id = pcall(function() return who:id() end)
                    if ok_who_id and obj_id then
                        local ok_alife, alife_obj = pcall(function()
                            return alife():object(obj_id)
                        end)
                        if ok_alife and alife_obj then
                            -- Пробуем получить секцию и найти профиль сталкера для получения имени
                            local ok_sname, sname = pcall(function()
                                return alife_obj:s_name()
                            end)
                            
                            if ok_sname and sname and sname ~= "" then
                                -- Проверяем, является ли это симулированным сталкером (sim_default_...)
                                if string.find(sname, "sim_default_stalker") then
                                    -- Для сим-сталкеров пробуем получить имя из профиля через story_id
                                    local ok_story, story_id = pcall(function()
                                        return alife_obj:story_id()
                                    end)
                                    
                                    if ok_story and story_id and story_id ~= -1 then
                                        -- Пытаемся найти профиль сталкера по story_id в db.story
                                        local story_data = db.story[story_id]
                                        if story_data and story_data.object then
                                            local ok_obj_name, obj_name = pcall(function() return story_data.object:name() end)
                                            if ok_obj_name and obj_name and obj_name ~= "" then
                                                display_name = obj_name
                                                safe_log("[DAMAGE_TRACKER] Display name from db.story: " .. obj_name)
                                            else
                                                -- Если имени нет, используем cleaned s_name
                                                display_name = sname
                                                display_name = string.gsub(display_name, "%d+$", "")
                                                display_name = string.gsub(display_name, "^sim_", "")
                                                safe_log("[DAMAGE_TRACKER] Display name from s_name (sim): " .. display_name)
                                            end
                                        else
                                            -- Если db.story нет, используем cleaned s_name
                                            display_name = sname
                                            display_name = string.gsub(display_name, "%d+$", "")
                                            display_name = string.gsub(display_name, "^sim_", "")
                                            safe_log("[DAMAGE_TRACKER] Display name from s_name (sim fallback): " .. display_name)
                                        end
                                    else
                                        -- Нет story_id, используем cleaned s_name
                                        display_name = sname
                                        display_name = string.gsub(display_name, "%d+$", "")
                                        display_name = string.gsub(display_name, "^sim_", "")
                                        safe_log("[DAMAGE_TRACKER] Display name from s_name (no story): " .. display_name)
                                    end
                                else
                                    -- Для уникальных NPC (esc_2_12_stalker_fanat и т.д.)
                                    display_name = sname
                                    -- Очищаем от цифр в конце и префиксов локаций
                                    display_name = string.gsub(display_name, "%d+$", "")
                                    display_name = string.gsub(display_name, "^esc_%d+_%d+_", "")
                                    -- Заменяем подчёркивания на пробелы для читаемости
                                    display_name = string.gsub(display_name, "_", " ")
                                    safe_log("[DAMAGE_TRACKER] Display name from s_name (unique): " .. display_name)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    safe_log("[DAMAGE_TRACKER] Source display name: " .. safe_tostring(display_name or "nil"))
    
    -- Определяем категорию урона используя систему из damage_modifier.txt
    -- Используем сохранённый тип урона из actor_on_before_hit
    local damage_category = get_damage_category(damage_type_before or -1, display_name, nil)
    
    safe_log("[DAMAGE_TRACKER] DAMAGE TYPE ID: " .. tostring(damage_type_before or -1))
    safe_log("[DAMAGE_TRACKER] DAMAGE CATEGORY: " .. damage_category)
    
    -- Если атакующий является человеком (сталкером), получаем название его оружия
    local weapon_name = nil
    if who and type(who) == "userdata" then
        local ok_is_stalker = pcall(function() return IsStalker(who) end)
        if ok_is_stalker and IsStalker(who) then
            -- Пытаемся получить оружие через best_weapon() или active_item()
            local ok_wpn, weapon = pcall(function() return who:best_weapon() end)
            if not ok_wpn or not weapon then
                ok_wpn, weapon = pcall(function() return who:active_item() end)
            end
            
            if ok_wpn and weapon and type(weapon) == "userdata" then
                -- Получаем секцию оружия (системное имя)
                local ok_sec, section = pcall(function() return weapon:section() end)
                if ok_sec and section then
                    weapon_name = section
                    safe_log("[DAMAGE_TRACKER] Attacker is human/stalker, weapon section: " .. weapon_name)
                end
            end
        end
    end

    if who then
        local hit_message = "[DAMAGE_TRACKER] CLASSIFIED HIT: [" .. damage_category .. "] from '" .. safe_tostring(display_name) .. "' - FINAL DAMAGE: " .. tostring(real_damage) .. " - Bone: " .. bone_name_ru
        -- Если атакующий человек и у него есть оружие, добавляем название оружия в лог
        if weapon_name then
            hit_message = hit_message .. " - Weapon: " .. weapon_name
        end
        safe_log(hit_message)
    else
        safe_log("[DAMAGE_TRACKER] Source: Nil (environment/fall/etc)")
        safe_log("[DAMAGE_TRACKER] CLASSIFIED HIT: [" .. damage_category .. "] from ENVIRONMENT - FINAL DAMAGE: " .. tostring(real_damage) .. " - Bone: " .. bone_name_ru)
    end

    safe_log("[DAMAGE_TRACKER] === END CLASSIFIED HIT ===")
end

-- Вызываем регистрацию при загрузке
on_game_start()