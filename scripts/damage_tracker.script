-- Функция для получения имени мутанта с обрезкой суффиксов
-- Примеры:
--   get_mutant_name("boar") -> "Кабан"
--   get_mutant_name("boar_02a_weak26696") -> "Кабан"
--   get_mutant_name("mutant_boar_strong") -> "Кабан"
--   get_mutant_name("m_boar") -> "Кабан"
local function get_mutant_name(mutant_id)
    if not mutant_id or type(mutant_id) ~= "string" then
        return nil
    end
    
    -- Обрезаем префиксы mutant_, m_ если есть
    local name = mutant_id
    if string.find(name, "^mutant_") then
        name = string.sub(name, 8)
    elseif string.find(name, "^m_") then
        name = string.sub(name, 3)
    end
    
    -- Обрезаем суффиксы: ищем базовое имя (только буквы до цифр или _)
    -- Примеры: boar_02a_weak26696 -> boar, flesh_strong -> flesh
    local base_name = string.match(name, "^([a-zA-Z]+)")
    
    if not base_name then
        base_name = name
    end
    
    -- Проверяем в словаре
    if mutant_names[base_name] then
        return mutant_names[base_name]
    end
    
    -- Если не нашли, пробуем оригинальное имя (для случаев типа pseudodog)
    if mutant_names[name] then
        return mutant_names[name]
    end
    
    return nil
end

